{
  "name": "law-partners",
  "version": "1.0.0",
  "description": "Law & Partners – landing page kancelarii prawnej",
  "scripts": {
    "start": "concurrently \"npm run dev\" \"npx serve public -l 3000\"",
    "dev": "tailwindcss -i ./css/input.css -o ./public/css/style.css --watch",
    "build": "mkdir -p public/css && tailwindcss -i ./css/input.css -o ./public/css/style.css --minify"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "tailwindcss": "^3.4.0"
  }
}
